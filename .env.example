# Copier ce fichier en .env et remplir les valeurs
# Le fichier .env n'est jamais commité (voir .gitignore)

# ── Brevo ──────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=newsletter@generations-medecins.fr
SENDER_NAME=Générations Médecins

# ── Gmail OAuth2 ────────────────────────────────────────────────
# Obtenir les credentials sur : https://console.cloud.google.com
# Puis générer le refresh token via OAuth Playground
GMAIL_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_SENDER=contact@generations-medecins.fr

